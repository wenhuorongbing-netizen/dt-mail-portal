# Supabase configuration — copy to .env.local and fill in real values.
# NEVER commit .env.local. NEVER use the service_role key here.

VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...your-anon-key-here

# Webmail URL shown to customers (do NOT derive from mailbox domain)
VITE_WEBMAIL_URL=https://webmail.buffjo.top
