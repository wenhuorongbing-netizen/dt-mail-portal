# Supabase configuration — copy to .env.local and fill in real values.
# NEVER commit .env.local. NEVER use the service_role key here.

VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...your-anon-key-here

# Optional fallback webmail URL for approved customer-login exception modes only.
# Wallet-only handovers must not show webmail.
VITE_WEBMAIL_URL=https://webmail.buffjo.top

# Operator short-login suffix. Typing "abc" logs in as abc@operators.localhost.
# If Supabase email confirmations are enabled, use a domain with real mailboxes.
VITE_OPERATOR_AUTH_DOMAIN=operators.localhost

# Keep this aligned with Supabase Auth password policy. Default 6 is recommended.
# VITE_OPERATOR_MIN_PASSWORD_LENGTH=6

# Optional. Leave empty for custom-domain/root deploys.
# For GitHub Pages project domains, use /repo-name/ (auto-detected in GitHub Actions).
# VITE_BASE_PATH=/dt-mail-portal/
